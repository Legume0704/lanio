# Required for querying for IMDb IDs with file names.
# Get one free: https://www.themoviedb.org/settings/api
TMDB_API_KEY=YOUR-TMDB-API-KEY-HERE

# URL used in video stream URLs, must be reachable from wherever Stremio is running.
# Use your server's LAN IP or hostname, e.g.:
BASE_URL=http://192.168.1.10:8078

# Optional: public-facing URL for the manifest install link (home page + startup logs).
# Stremio requires HTTPS with a valid TLS certificate to install addons directly,
# so this should be an https:// URL if you're installing via Stremio's addon page.
# If you're using AIOStreams as a proxy, you can leave this unset; AIOStreams will
# reference this server's BASE_URL internally and handle TLS itself.
# PUBLIC_URL=https://stremio.yourdomain.com

# Optional overrides
# PORT=8078

# Required for Tailscale setup
# Generate here: https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=YOUR-TAILSCALE-AUTH-KEY-HERE 
